{
  "category": "each rule trigger",
  "description": "Test file too large emits the canonical JSON warning.",
  "args": [
    "check",
    "--output-format",
    "json",
    "--target",
    "tq",
    "--select",
    "test-file-too-large",
    "--max-test-file-non-blank-lines",
    "3"
  ],
  "stdout_format": "json",
  "expectation": {
    "mode": "match",
    "expected": {
      "exit_code": 0,
      "stdout": "expected.stdout.json"
    }
  }
}
