{
  "name": "tq-docs",
  "private": true,
  "type": "module",
  "scripts": {
    "docs:dev": "vitepress dev docs",
    "docs:build": "npm run docs:generate && vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "docs:generate": "cargo run -p tq-docsgen --locked -- generate all",
    "docs:rules:generate": "cargo run -p tq-docsgen --locked -- generate rules",
    "docs:cli:generate": "cargo run -p tq-docsgen --locked -- generate cli",
    "docs:config:generate": "cargo run -p tq-docsgen --locked -- generate config",
    "package:verify-contents": "cargo run -p tq-release --locked -- verify-artifact-contents"
  },
  "devDependencies": {
    "vitepress": "1.6.4"
  },
  "overrides": {
    "vite": "6.4.2",
    "esbuild": "0.27.3"
  }
}
